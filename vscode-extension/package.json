{
  "name": "patchflow-vscode",
  "displayName": "Patchflow",
  "description": "VS Code integration for Patchflow branch analysis, clean previews, and PR status.",
  "version": "0.0.1",
  "publisher": "neil-n4",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:patchflow.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "patchflow.open",
        "title": "Patchflow: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Patchflow",
      "properties": {
        "patchflow.cliPath": {
          "type": "string",
          "default": "patchflow",
          "description": "Path to the Patchflow CLI executable used by the VS Code extension."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "npm run build && node --test test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.7.2"
  }
}
